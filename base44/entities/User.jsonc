{
  "name": "User",
  "type": "object",
  "properties": {
    "role": {
      "type": "string",
      "enum": [
        "admin",
        "manager",
        "user"
      ],
      "default": "user",
      "description": "User role: admin (full access), manager (manager files), user (universal + personal)"
    },
    "department": {
      "type": "string",
      "description": "User's department"
    }
  }
}